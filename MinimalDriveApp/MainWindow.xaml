<mah:MetroWindow x:Class="MinimalDriveApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:MinimalDriveApp.Views"
        mc:Ignorable="d"
        Title="ArchiveStack Manager" Height="620" Width="1440"
        Background="#12121E"
        TitleCharacterCasing="Normal">

    <mah:MetroWindow.Resources>
        <views:BytesToGbConverter x:Key="BytesToGb" />
        <views:NullableDateConverter x:Key="NullableDate" />
    </mah:MetroWindow.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <!-- Drive table -->
            <ColumnDefinition Width="*"/>
            <!-- Dashboard panel — fixed width -->
            <ColumnDefinition Width="360"/>
        </Grid.ColumnDefinitions>

        <!-- ── Left: Drive DataGrid ── -->
        <DataGrid Grid.Column="0"
                  ItemsSource="{Binding Drives}"
                  SelectedItem="{Binding SelectedDrive, Mode=TwoWay}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserSortColumns="True"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column"
                  SelectionMode="Single"
                  Margin="8,8,4,8">

            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow" BasedOn="{StaticResource MahApps.Styles.DataGridRow}">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsHealthWarning}" Value="True">
                            <Setter Property="Background" Value="#CC6000"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsOutdatedBackup}" Value="True">
                            <Setter Property="Background" Value="#7A7000"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>

            <DataGrid.Columns>
                <!-- 1: Tick Box -->
                <DataGridCheckBoxColumn Header="" Width="32" IsReadOnly="False" />

                <!-- 2: Drive Letter -->
                <DataGridTextColumn Header="Drive" Width="60"
                                    Binding="{Binding DriveLetter}" />

                <!-- 3: Serial Number -->
                <DataGridTextColumn Header="Serial" Width="160"
                                    Binding="{Binding SerialNumber}" />

                <!-- 4: Drive Name -->
                <DataGridTextColumn Header="Name" Width="140"
                                    Binding="{Binding VolumeName}" />

                <!-- 5: Drive Type -->
                <DataGridTextColumn Header="Type" Width="100"
                                    Binding="{Binding DriveType}" />

                <!-- 6: File System -->
                <DataGridTextColumn Header="File System" Width="80"
                                    Binding="{Binding FileSystem}" />

                <!-- 7: Capacity -->
                <DataGridTextColumn Header="Capacity" Width="90"
                                    Binding="{Binding Capacity, Converter={StaticResource BytesToGb}}" />

                <!-- 8: Used Space -->
                <DataGridTextColumn Header="Used" Width="90"
                                    Binding="{Binding UsedSpace, Converter={StaticResource BytesToGb}}" />

                <!-- 9: Free Space -->
                <DataGridTextColumn Header="Free" Width="90"
                                    Binding="{Binding FreeSpace, Converter={StaticResource BytesToGb}}" />

                <!-- 10: Health Status -->
                <DataGridTextColumn Header="Health" Width="90"
                                    Binding="{Binding HealthStatus}" />

                <!-- 11: Last Updated -->
                <DataGridTextColumn Header="Last Updated" Width="130"
                                    Binding="{Binding LastUpdated, Converter={StaticResource NullableDate}}" />

                <!-- 12: Last Backed Up -->
                <DataGridTextColumn Header="Last Backed Up" Width="130"
                                    Binding="{Binding LastBackedUp, Converter={StaticResource NullableDate}}" />

                <!-- 13: Connection Type -->
                <DataGridTextColumn Header="Connection" Width="90"
                                    Binding="{Binding ConnectionType}" />
            </DataGrid.Columns>
        </DataGrid>

        <!-- ── Right: Drive Dashboard panel ── -->
        <views:DriveDashboardView Grid.Column="1"
                                  DataContext="{Binding Dashboard}"
                                  Margin="4,8,8,8"/>
    </Grid>
</mah:MetroWindow>
