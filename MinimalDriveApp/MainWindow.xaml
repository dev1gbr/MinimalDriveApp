<ui:FluentWindow x:Class="MinimalDriveApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:MinimalDriveApp.Views"
        mc:Ignorable="d"
        Title="ArchiveStack Manager" Height="760" Width="1280"
        Background="{StaticResource Brush.Background.Window}">

    <ui:FluentWindow.Resources>
        <views:BytesToGbConverter x:Key="BytesToGb" />
        <views:NullableDateConverter x:Key="NullableDate" />
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="240"/>
        </Grid.RowDefinitions>

        <!-- ── Top: Drive DataGrid ── -->
        <DataGrid Grid.Row="0"
                  ItemsSource="{Binding Drives}"
                  SelectedItem="{Binding SelectedDrive, Mode=TwoWay}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserSortColumns="True"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column"
                  SelectionMode="Single"
                  Margin="{StaticResource Spacing.DataGrid.Margin}">

            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsHealthWarning}" Value="True">
                            <Setter Property="Background" Value="{StaticResource Brush.Row.HealthWarning}"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsOutdatedBackup}" Value="True">
                            <Setter Property="Background" Value="{StaticResource Brush.Row.OutdatedBackup}"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>

            <DataGrid.Columns>
                <DataGridCheckBoxColumn Header="" Width="32" IsReadOnly="False" />
                <DataGridTextColumn Header="Drive"          Width="60"  Binding="{Binding DriveLetter}" />
                <DataGridTextColumn Header="Serial"         Width="160" Binding="{Binding SerialNumber}" />
                <DataGridTextColumn Header="Name"           Width="140" Binding="{Binding VolumeName}" />
                <DataGridTextColumn Header="Type"           Width="100" Binding="{Binding DriveType}" />
                <DataGridTextColumn Header="File System"    Width="80"  Binding="{Binding FileSystem}" />
                <DataGridTextColumn Header="Capacity"       Width="90"  Binding="{Binding Capacity,     Converter={StaticResource BytesToGb}}" />
                <DataGridTextColumn Header="Used"           Width="90"  Binding="{Binding UsedSpace,    Converter={StaticResource BytesToGb}}" />
                <DataGridTextColumn Header="Free"           Width="90"  Binding="{Binding FreeSpace,    Converter={StaticResource BytesToGb}}" />
                <DataGridTextColumn Header="Health"         Width="90"  Binding="{Binding HealthStatus}" />
                <DataGridTextColumn Header="Last Updated"   Width="130" Binding="{Binding LastUpdated,  Converter={StaticResource NullableDate}}" />
                <DataGridTextColumn Header="Last Backed Up" Width="130" Binding="{Binding LastBackedUp, Converter={StaticResource NullableDate}}" />
                <DataGridTextColumn Header="Connection"     Width="90"  Binding="{Binding ConnectionType}" />
            </DataGrid.Columns>
        </DataGrid>

        <!-- ── Bottom: Drive Dashboard panel ── -->
        <views:DriveDashboardView Grid.Row="1"
                                  DataContext="{Binding Dashboard}"/>
    </Grid>
</ui:FluentWindow>
