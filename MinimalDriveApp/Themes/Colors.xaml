<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ── Background surfaces ── -->
    <Color x:Key="Color.Background.Window">#12121E</Color>
    <Color x:Key="Color.Background.Card">#1E1E36</Color>
    <Color x:Key="Color.Background.Ring">#2A2A4A</Color>

    <SolidColorBrush x:Key="Brush.Background.Window" Color="{StaticResource Color.Background.Window}"/>
    <SolidColorBrush x:Key="Brush.Background.Card"   Color="{StaticResource Color.Background.Card}"/>
    <SolidColorBrush x:Key="Brush.Background.Ring"   Color="{StaticResource Color.Background.Ring}"/>

    <!-- ── Accent ── -->
    <Color x:Key="Color.Accent.Blue">#0078D4</Color>
    <SolidColorBrush x:Key="Brush.Accent.Blue" Color="{StaticResource Color.Accent.Blue}"/>

    <!-- ── Text ── -->
    <Color x:Key="Color.Text.Primary">#FFFFFF</Color>
    <Color x:Key="Color.Text.Secondary">#CCCCDD</Color>
    <Color x:Key="Color.Text.Muted">#6666AA</Color>
    <Color x:Key="Color.Text.Faint">#44446A</Color>

    <SolidColorBrush x:Key="Brush.Text.Primary"   Color="{StaticResource Color.Text.Primary}"/>
    <SolidColorBrush x:Key="Brush.Text.Secondary" Color="{StaticResource Color.Text.Secondary}"/>
    <SolidColorBrush x:Key="Brush.Text.Muted"     Color="{StaticResource Color.Text.Muted}"/>
    <SolidColorBrush x:Key="Brush.Text.Faint"     Color="{StaticResource Color.Text.Faint}"/>

    <!-- ── Stat tile values ── -->
    <SolidColorBrush x:Key="Brush.Stat.Used"     Color="{StaticResource Color.Accent.Blue}"/>
    <SolidColorBrush x:Key="Brush.Stat.Free"     Color="#4EC9B0"/>
    <SolidColorBrush x:Key="Brush.Stat.Capacity" Color="#888899"/>

    <!-- ── Status / health ── -->
    <SolidColorBrush x:Key="Brush.Status.Ok"      Color="#10B981"/>
    <SolidColorBrush x:Key="Brush.Status.Warning" Color="#FF8C00"/>

    <!-- ── DataGrid row highlights ── -->
    <SolidColorBrush x:Key="Brush.Row.HealthWarning"  Color="#CC6000"/>
    <SolidColorBrush x:Key="Brush.Row.OutdatedBackup" Color="#7A7000"/>

</ResourceDictionary>
