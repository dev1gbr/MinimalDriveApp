<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- ── Font family ── -->
    <FontFamily x:Key="Font.Family.Default">Segoe UI</FontFamily>
    <FontFamily x:Key="Font.Family.Icons">Segoe MDL2 Assets</FontFamily>

    <!-- ── Font sizes ── -->
    <sys:Double x:Key="Font.Size.XSmall">10</sys:Double>
    <sys:Double x:Key="Font.Size.Small">11</sys:Double>
    <sys:Double x:Key="Font.Size.Body">12</sys:Double>
    <sys:Double x:Key="Font.Size.Subtitle">13</sys:Double>
    <sys:Double x:Key="Font.Size.Title">15</sys:Double>
    <sys:Double x:Key="Font.Size.Metric">18</sys:Double>
    <sys:Double x:Key="Font.Size.MetricLarge">22</sys:Double>
    <sys:Double x:Key="Font.Size.Icon">28</sys:Double>

</ResourceDictionary>
