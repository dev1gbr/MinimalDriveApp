<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        Vector icon resources — DrawingImage (scalable, no bitmap files needed).
        ViewBox: 24 x 24 (Material Design grid).
        Fill:    #0078D4 (Fluent blue accent).
        Usage:   LargeIcon="{StaticResource Icon.Refresh}" on fluent:Button.
    -->

    <!-- ── Refresh (circular arrows) ── -->
    <DrawingImage x:Key="Icon.Refresh">
        <DrawingImage.Drawing>
            <DrawingGroup>
                <DrawingGroup.ClipGeometry>
                    <RectangleGeometry Rect="0,0,24,24"/>
                </DrawingGroup.ClipGeometry>
                <GeometryDrawing Brush="#FF0078D4">
                    <GeometryDrawing.Geometry>
                        <PathGeometry FillRule="NonZero"
                            Figures="M17.65,6.35C16.2,4.9 14.21,4 12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20C15.73,20 18.84,17.45 19.73,14H17.65C16.83,16.33 14.61,18 12,18A6,6 0 0,1 6,12A6,6 0 0,1 12,6C13.66,6 15.14,6.69 16.22,7.78L13,11H20V4L17.65,6.35Z"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
            </DrawingGroup>
        </DrawingImage.Drawing>
    </DrawingImage>

    <!-- ── Set Up Drive (database / storage cylinder) ── -->
    <DrawingImage x:Key="Icon.SetUpDrive">
        <DrawingImage.Drawing>
            <DrawingGroup>
                <DrawingGroup.ClipGeometry>
                    <RectangleGeometry Rect="0,0,24,24"/>
                </DrawingGroup.ClipGeometry>
                <GeometryDrawing Brush="#FF0078D4">
                    <GeometryDrawing.Geometry>
                        <PathGeometry FillRule="NonZero"
                            Figures="M12,3C7.58,3 4,4.79 4,7C4,9.21 7.58,11 12,11C16.42,11 20,9.21 20,7C20,4.79 16.42,3 12,3 M4,9V12C4,14.21 7.58,16 12,16C16.42,16 20,14.21 20,12V9C20,11.21 16.42,13 12,13C7.58,13 4,11.21 4,9 M4,14V17C4,19.21 7.58,21 12,21C16.42,21 20,19.21 20,17V14C20,16.21 16.42,18 12,18C7.58,18 4,16.21 4,14Z"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
            </DrawingGroup>
        </DrawingImage.Drawing>
    </DrawingImage>

    <!-- ── Dashboard (2×2 tile grid) ── -->
    <DrawingImage x:Key="Icon.Dashboard">
        <DrawingImage.Drawing>
            <DrawingGroup>
                <DrawingGroup.ClipGeometry>
                    <RectangleGeometry Rect="0,0,24,24"/>
                </DrawingGroup.ClipGeometry>
                <GeometryDrawing Brush="#FF0078D4">
                    <GeometryDrawing.Geometry>
                        <PathGeometry FillRule="NonZero"
                            Figures="M13,3V9H21V3H13 M13,21H21V11H13V21 M3,21H11V15H3V21 M3,13H11V3H3V13Z"/>
