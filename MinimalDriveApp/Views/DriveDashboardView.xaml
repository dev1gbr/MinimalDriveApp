<UserControl x:Class="MinimalDriveApp.Views.DriveDashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             xmlns:views="clr-namespace:MinimalDriveApp.Views"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="240" d:DesignWidth="1200"
             Background="#12121E">

    <UserControl.Resources>
        <views:BoolToVisibilityConverter x:Key="BoolToVis"/>

        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background"   Value="#1E1E36"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding"      Value="14,12"/>
        </Style>

        <Style x:Key="MutedLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#6666AA"/>
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Margin"     Value="0,0,0,3"/>
        </Style>

        <Style x:Key="CardValue" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="FontSize"   Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
        </Style>

        <Style x:Key="DetailLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#6666AA"/>
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Margin"     Value="0,0,12,6"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="DetailValue" TargetType="TextBlock">
            <Setter Property="Foreground"   Value="#CCCCDD"/>
            <Setter Property="FontSize"     Value="12"/>
            <Setter Property="FontFamily"   Value="Segoe UI"/>
            <Setter Property="Margin"       Value="0,0,0,6"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="8,4,8,8">

        <!-- ── Empty state ── -->
        <Border Style="{StaticResource Card}"
                Visibility="{Binding HasDrive, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="&#xE88A;" FontFamily="Segoe MDL2 Assets" FontSize="28"
                           Foreground="#2A2A4A" VerticalAlignment="Center" Margin="0,0,12,0"/>
                <TextBlock Text="Select a drive above to view its details"
                           Foreground="#44446A" FontSize="13" FontFamily="Segoe UI"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- ── Dashboard — horizontal strip ── -->
        <Grid Visibility="{Binding HasDrive, Converter={StaticResource BoolToVis}}">
            <Grid.ColumnDefinitions>
                <!-- Donut -->
                <ColumnDefinition Width="220"/>
                <!-- Stat tiles -->
                <ColumnDefinition Width="260"/>
                <!-- Details -->
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ── Col 0: Header + Donut ── -->
            <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,6,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,6">
                        <TextBlock Text="{Binding HeaderTitle}"
                                   Foreground="#FFFFFF" FontSize="15" FontWeight="Bold"
                                   FontFamily="Segoe UI" TextTrimming="CharacterEllipsis"/>
                        <TextBlock Text="{Binding HeaderSubtitle}"
                                   Foreground="#6666AA" FontSize="10" FontFamily="Segoe UI"
                                   Margin="0,3,0,0" TextTrimming="CharacterEllipsis"/>
                    </StackPanel>

                    <!-- Donut chart -->
                    <lvc:PieChart Grid.Row="1"
                                  Series="{Binding DonutSeries}"
                                  LegendPosition="Hidden"
                                  AnimationsSpeed="0:0:0.4"
                                  Background="Transparent"
                                  InitialRotation="-90"
                                  TooltipPosition="Hidden"
                                  MinHeight="120">

                        <!-- Centre percent overlay via InnerLabel workaround: we overlay a TextBlock in a Grid -->
                    </lvc:PieChart>

                    <!-- Overlay label in centre of donut -->
                    <Grid Grid.Row="1" IsHitTestVisible="False">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="{Binding UsedPercentFormatted}"
                                       Foreground="#FFFFFF" FontSize="20" FontWeight="Bold"
                                       FontFamily="Segoe UI" TextAlignment="Center"/>
                            <TextBlock Text="used" Foreground="#6666AA" FontSize="10"
                                       FontFamily="Segoe UI" TextAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

            <!-- ── Col 1: Stat tiles ── -->
            <Grid Grid.Column="1" Margin="0,0,6,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="6"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="6"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Used -->
                <Border Grid.Row="0" Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource MutedLabel}" Text="Used Space"/>
                        <TextBlock Style="{StaticResource CardValue}" Text="{Binding UsedSpaceFormatted}"
                                   Foreground="#0078D4"/>
                    </StackPanel>
                </Border>

                <!-- Free -->
                <Border Grid.Row="2" Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource MutedLabel}" Text="Free Space"/>
                        <TextBlock Style="{StaticResource CardValue}" Text="{Binding FreeSpaceFormatted}"
                                   Foreground="#4EC9B0"/>
                    </StackPanel>
                </Border>

                <!-- Total -->
                <Border Grid.Row="4" Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource MutedLabel}" Text="Total Capacity"/>
                        <TextBlock Style="{StaticResource CardValue}" Text="{Binding CapacityFormatted}"
                                   Foreground="#888899"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ── Col 2: Details ── -->
            <Border Grid.Column="2" Style="{StaticResource Card}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="24"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Left column -->
                    <!-- Health -->
                    <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource DetailLabel}" Text="Health"/>
                    <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal">
                        <TextBlock Text="{Binding HealthIcon}" FontSize="11" Margin="0,0,5,6" VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#10B981"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsHealthOk}" Value="False">
                                            <Setter Property="Foreground" Value="#FF8C00"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock Style="{StaticResource DetailValue}" Text="{Binding HealthStatus}"/>
                    </StackPanel>

                    <!-- Status -->
                    <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource DetailLabel}" Text="Status"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" Style="{StaticResource DetailValue}" Text="{Binding StatusLabel}"/>

                    <!-- Serial -->
                    <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource DetailLabel}" Text="Serial"/>
                    <TextBlock Grid.Row="2" Grid.Column="1" Style="{StaticResource DetailValue}"
                               Text="{Binding SerialNumber}" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"/>

                    <!-- Right column -->
                    <!-- Connection -->
                    <TextBlock Grid.Row="0" Grid.Column="3" Style="{StaticResource DetailLabel}" Text="Connection"/>
                    <TextBlock Grid.Row="0" Grid.Column="4" Style="{StaticResource DetailValue}" Text="{Binding ConnectionType}"/>

                    <!-- File System -->
                    <TextBlock Grid.Row="1" Grid.Column="3" Style="{StaticResource DetailLabel}" Text="File System"/>
                    <TextBlock Grid.Row="1" Grid.Column="4" Style="{StaticResource DetailValue}" Text="{Binding FileSystem}"/>

                    <!-- Drive Type -->
                    <TextBlock Grid.Row="2" Grid.Column="3" Style="{StaticResource DetailLabel}" Text="Drive Type"/>
                    <TextBlock Grid.Row="2" Grid.Column="4" Style="{StaticResource DetailValue}" Text="{Binding DriveType}"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
