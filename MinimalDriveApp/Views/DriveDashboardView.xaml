<UserControl x:Class="MinimalDriveApp.Views.DriveDashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
             xmlns:views="clr-namespace:MinimalDriveApp.Views"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="620" d:DesignWidth="360"
             Background="#12121E">

    <UserControl.Resources>
        <views:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <views:DonutArcConverter         x:Key="DonutArc"/>

        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background"   Value="#1E1E36"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding"      Value="14,12"/>
            <Setter Property="Margin"       Value="0,0,0,8"/>
        </Style>

        <Style x:Key="MutedLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#6666AA"/>
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Margin"     Value="0,0,0,2"/>
        </Style>

        <Style x:Key="CardValue" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="FontSize"   Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
        </Style>

        <Style x:Key="DetailValue" TargetType="TextBlock">
            <Setter Property="Foreground"   Value="#CCCCDD"/>
            <Setter Property="FontSize"     Value="12"/>
            <Setter Property="FontFamily"   Value="Segoe UI"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
    </UserControl.Resources>

    <Grid>

        <!-- ── Empty state ── -->
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                    Visibility="{Binding HasDrive, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}">
            <TextBlock Text="&#xE88A;" FontFamily="Segoe MDL2 Assets" FontSize="52"
                       Foreground="#2A2A4A" HorizontalAlignment="Center"/>
            <TextBlock Text="Select a drive to view details"
                       Foreground="#44446A" FontSize="13" FontFamily="Segoe UI"
                       HorizontalAlignment="Center" Margin="0,14,0,0"/>
        </StackPanel>

        <!-- ── Dashboard ── -->
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      Visibility="{Binding HasDrive, Converter={StaticResource BoolToVis}}">
            <StackPanel Margin="12,12,12,16">

                <!-- ── Header ── -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="{Binding HeaderTitle}"
                                   Foreground="#FFFFFF" FontSize="20" FontWeight="Bold"
                                   FontFamily="Segoe UI" TextTrimming="CharacterEllipsis"/>
                        <TextBlock Text="{Binding HeaderSubtitle}"
                                   Foreground="#6666AA" FontSize="11" FontFamily="Segoe UI"
                                   Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>

                <!-- ── Donut chart ── -->
                <Border Style="{StaticResource Card}" Padding="0,16">
                    <Grid HorizontalAlignment="Center">
                        <!-- size: 2×outerRadius = 160 -->
                        <Canvas Width="160" Height="160">

                            <!-- background ring (free space) -->
                            <Ellipse Width="160" Height="160"
                                     Fill="#2A2A4A"/>

                            <!-- used arc -->
                            <Path Fill="#0078D4">
                                <Path.Data>
                                    <MultiBinding Converter="{StaticResource DonutArc}"
                                                  ConverterParameter="80,52">
                                        <Binding Path="UsedSpace"/>
                                        <Binding Path="Capacity"/>
                                    </MultiBinding>
                                </Path.Data>
                            </Path>

                            <!-- donut hole -->
                            <Ellipse Canvas.Left="28" Canvas.Top="28"
                                     Width="104" Height="104"
                                     Fill="#12121E"/>

                            <!-- centre label -->
                            <StackPanel Canvas.Left="0" Canvas.Top="52"
                                        Width="160" HorizontalAlignment="Center">
                                <TextBlock Text="{Binding UsedPercentFormatted}"
                                           Foreground="#FFFFFF" FontSize="24" FontWeight="Bold"
                                           FontFamily="Segoe UI" TextAlignment="Center"/>
                                <TextBlock Text="used"
                                           Foreground="#6666AA" FontSize="11"
                                           FontFamily="Segoe UI" TextAlignment="Center"/>
                            </StackPanel>
                        </Canvas>

                        <!-- legend -->
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    Margin="0,8,0,0"
                                    VerticalAlignment="Bottom">
                            <Ellipse Width="10" Height="10" Fill="#0078D4" Margin="0,0,5,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Used" Foreground="#AAAACC" FontSize="11" FontFamily="Segoe UI" Margin="0,0,16,0"/>
                            <Ellipse Width="10" Height="10" Fill="#2A2A4A" Margin="0,0,5,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Free" Foreground="#AAAACC" FontSize="11" FontFamily="Segoe UI"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ── Stat tiles ── -->
                <UniformGrid Columns="3" Margin="0,0,0,8">
                    <Border Background="#1E1E36" CornerRadius="8" Padding="10,10" Margin="0,0,4,0">
                        <StackPanel>
                            <TextBlock Style="{StaticResource MutedLabel}" Text="Used"/>
                            <TextBlock Style="{StaticResource CardValue}" Text="{Binding UsedSpaceFormatted}" FontSize="14"/>
                        </StackPanel>
                    </Border>
                    <Border Background="#1E1E36" CornerRadius="8" Padding="10,10" Margin="2,0">
                        <StackPanel>
                            <TextBlock Style="{StaticResource MutedLabel}" Text="Free"/>
                            <TextBlock Style="{StaticResource CardValue}" Text="{Binding FreeSpaceFormatted}"
                                       Foreground="#4EC9B0" FontSize="14"/>
                        </StackPanel>
                    </Border>
                    <Border Background="#1E1E36" CornerRadius="8" Padding="10,10" Margin="4,0,0,0">
                        <StackPanel>
                            <TextBlock Style="{StaticResource MutedLabel}" Text="Total"/>
                            <TextBlock Style="{StaticResource CardValue}" Text="{Binding CapacityFormatted}"
                                       Foreground="#888899" FontSize="14"/>
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <!-- ── Details card ── -->
                <Border Style="{StaticResource Card}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Health -->
                        <TextBlock Grid.Row="0" Grid.Column="0"
                                   Style="{StaticResource MutedLabel}" Text="Health"
                                   Margin="0,0,20,10" VerticalAlignment="Center"/>
                        <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBlock Text="{Binding HealthIcon}" FontSize="12" Margin="0,0,6,0" VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#10B981"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsHealthOk}" Value="False">
                                                <Setter Property="Foreground" Value="#FF8C00"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBlock Style="{StaticResource DetailValue}" Text="{Binding HealthStatus}" VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Status -->
                        <TextBlock Grid.Row="1" Grid.Column="0"
                                   Style="{StaticResource MutedLabel}" Text="Status"
                                   Margin="0,0,20,10"/>
                        <TextBlock Grid.Row="1" Grid.Column="1"
                                   Style="{StaticResource DetailValue}" Text="{Binding StatusLabel}"
                                   Margin="0,0,0,10"/>

                        <!-- Connection -->
                        <TextBlock Grid.Row="2" Grid.Column="0"
                                   Style="{StaticResource MutedLabel}" Text="Connection"
                                   Margin="0,0,20,10"/>
                        <TextBlock Grid.Row="2" Grid.Column="1"
                                   Style="{StaticResource DetailValue}" Text="{Binding ConnectionType}"
                                   Margin="0,0,0,10"/>

                        <!-- File System -->
                        <TextBlock Grid.Row="3" Grid.Column="0"
                                   Style="{StaticResource MutedLabel}" Text="File System"
                                   Margin="0,0,20,10"/>
                        <TextBlock Grid.Row="3" Grid.Column="1"
                                   Style="{StaticResource DetailValue}" Text="{Binding FileSystem}"
                                   Margin="0,0,0,10"/>

                        <!-- Drive Type -->
                        <TextBlock Grid.Row="4" Grid.Column="0"
                                   Style="{StaticResource MutedLabel}" Text="Drive Type"
                                   Margin="0,0,20,10"/>
                        <TextBlock Grid.Row="4" Grid.Column="1"
                                   Style="{StaticResource DetailValue}" Text="{Binding DriveType}"
                                   Margin="0,0,0,10"/>

                        <!-- Serial -->
                        <TextBlock Grid.Row="5" Grid.Column="0"
                                   Style="{StaticResource MutedLabel}" Text="Serial"
                                   Margin="0,0,20,0"/>
                        <TextBlock Grid.Row="5" Grid.Column="1"
                                   Style="{StaticResource DetailValue}" Text="{Binding SerialNumber}"
                                   TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"/>
                    </Grid>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
