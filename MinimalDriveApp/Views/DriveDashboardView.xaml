<UserControl x:Class="MinimalDriveApp.Views.DriveDashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:MinimalDriveApp.Views"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="240" d:DesignWidth="1200"
             Background="{StaticResource Brush.Background.Window}">

    <Grid Margin="{StaticResource Spacing.Panel.Margin}">

        <!-- ── Empty state ── -->
        <Border Style="{StaticResource Style.Card}"
                Visibility="{Binding HasDrive, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="&#xE88A;"
                           FontFamily="{StaticResource Font.Family.Icons}"
                           FontSize="{StaticResource Font.Size.Icon}"
                           Foreground="{StaticResource Brush.Background.Ring}"
                           VerticalAlignment="Center"
                           Margin="{StaticResource Spacing.Icon.MarginRight}"/>
                <TextBlock Text="Select a drive above to view its details"
                           Foreground="{StaticResource Brush.Text.Faint}"
                           FontSize="{StaticResource Font.Size.Subtitle}"
                           FontFamily="{StaticResource Font.Family.Default}"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- ── Dashboard — horizontal strip ── -->
        <Grid Visibility="{Binding HasDrive, Converter={StaticResource BoolToVis}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ── Col 0: Header + Donut ── -->
            <Border Grid.Column="0" Style="{StaticResource Style.Card}"
                    Margin="{StaticResource Spacing.Column.GapRight}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="{StaticResource Spacing.Header.Margin}">
                        <TextBlock Text="{Binding HeaderTitle}"
                                   Foreground="{StaticResource Brush.Text.Primary}"
                                   FontSize="{StaticResource Font.Size.Title}"
                                   FontWeight="Bold"
                                   FontFamily="{StaticResource Font.Family.Default}"
                                   TextTrimming="CharacterEllipsis"/>
                        <TextBlock Text="{Binding HeaderSubtitle}"
                                   Foreground="{StaticResource Brush.Text.Muted}"
                                   FontSize="{StaticResource Font.Size.XSmall}"
                                   FontFamily="{StaticResource Font.Family.Default}"
                                   Margin="{StaticResource Spacing.Subtitle.Margin}"
                                   TextTrimming="CharacterEllipsis"/>
                    </StackPanel>

                    <!-- LiveCharts2 donut chart -->
                    <Grid Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <lvc:PieChart Series="{Binding DonutSeries}"
                                      Width="160" Height="160"
                                      InitialRotation="-90"
                                      AnimationsSpeed="0:0:0.4"
                                      Background="Transparent"
                                      IsHitTestVisible="False"/>
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="{Binding UsedPercentFormatted}"
                                       Foreground="{StaticResource Brush.Text.Primary}"
                                       FontSize="{StaticResource Font.Size.MetricLarge}"
                                       FontWeight="Bold"
                                       FontFamily="{StaticResource Font.Family.Default}"
                                       TextAlignment="Center"/>
                            <TextBlock Text="used"
                                       Foreground="{StaticResource Brush.Text.Muted}"
                                       FontSize="{StaticResource Font.Size.XSmall}"
                                       FontFamily="{StaticResource Font.Family.Default}"
                                       TextAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

            <!-- ── Col 1: Stat tiles ── -->
            <Grid Grid.Column="1" Margin="{StaticResource Spacing.Column.GapRight}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="{StaticResource Spacing.Tile.Gap}"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="{StaticResource Spacing.Tile.Gap}"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Style="{StaticResource Style.Card}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource Style.Label.Muted}" Text="Used Space"/>
                        <TextBlock Style="{StaticResource Style.Value.Metric}"
                                   Text="{Binding UsedSpaceFormatted}"
                                   Foreground="{StaticResource Brush.Stat.Used}"/>
                    </StackPanel>
                </Border>

                <Border Grid.Row="2" Style="{StaticResource Style.Card}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource Style.Label.Muted}" Text="Free Space"/>
                        <TextBlock Style="{StaticResource Style.Value.Metric}"
                                   Text="{Binding FreeSpaceFormatted}"
                                   Foreground="{StaticResource Brush.Stat.Free}"/>
                    </StackPanel>
                </Border>

                <Border Grid.Row="4" Style="{StaticResource Style.Card}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource Style.Label.Muted}" Text="Total Capacity"/>
                        <TextBlock Style="{StaticResource Style.Value.Metric}"
                                   Text="{Binding CapacityFormatted}"
                                   Foreground="{StaticResource Brush.Stat.Capacity}"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ── Col 2: Details ── -->
            <Border Grid.Column="2" Style="{StaticResource Style.Card}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="24"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Health -->
                    <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource Style.Label.Detail}" Text="Health"/>
                    <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal">
                        <TextBlock Text="{Binding HealthIcon}"
                                   FontSize="{StaticResource Font.Size.Small}"
                                   Margin="{StaticResource Spacing.HealthIcon.Margin}"
                                   VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{StaticResource Brush.Status.Ok}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsHealthOk}" Value="False">
                                            <Setter Property="Foreground" Value="{StaticResource Brush.Status.Warning}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock Style="{StaticResource Style.Value.Detail}"
                                   Text="{Binding HealthStatus}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Status -->
                    <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource Style.Label.Detail}" Text="Status"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" Style="{StaticResource Style.Value.Detail}" Text="{Binding StatusLabel}"/>

                    <!-- Serial -->
                    <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource Style.Label.Detail}" Text="Serial"/>
                    <TextBlock Grid.Row="2" Grid.Column="1" Style="{StaticResource Style.Value.Detail}"
                               Text="{Binding SerialNumber}"
                               TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"/>

                    <!-- Connection -->
                    <TextBlock Grid.Row="0" Grid.Column="3" Style="{StaticResource Style.Label.Detail}" Text="Connection"/>
                    <TextBlock Grid.Row="0" Grid.Column="4" Style="{StaticResource Style.Value.Detail}" Text="{Binding ConnectionType}"/>

                    <!-- File System -->
                    <TextBlock Grid.Row="1" Grid.Column="3" Style="{StaticResource Style.Label.Detail}" Text="File System"/>
                    <TextBlock Grid.Row="1" Grid.Column="4" Style="{StaticResource Style.Value.Detail}" Text="{Binding FileSystem}"/>

                    <!-- Drive Type -->
                    <TextBlock Grid.Row="2" Grid.Column="3" Style="{StaticResource Style.Label.Detail}" Text="Drive Type"/>
                    <TextBlock Grid.Row="2" Grid.Column="4" Style="{StaticResource Style.Value.Detail}" Text="{Binding DriveType}"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
